{
  "name": "quadlo",
  "private": true,
  "version": "1.0.0",
  "description": "Quadlo — 3D modeling and pixel art tool",
  "type": "module",
  "productName": "Quadlo",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "tsc -b && vite build --configLoader runner",
    "preview": "vite preview",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "validate:primitives": "tsx scripts/validate-primitives.ts",
    "benchmark:history": "tsx scripts/benchmark-history.ts",
    "benchmark:viewport": "tsx scripts/benchmark-viewport-geometry.ts",
    "app:dev": "wails dev",
    "app:icon": "python scripts/generate-appicon.py",
    "app:build": "npm run app:icon && wails build"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.173.0",
    "three-mesh-bvh": "^0.9.11",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.173.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.5"
  }
}
